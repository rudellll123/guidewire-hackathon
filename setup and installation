Quick Start (Docker — Recommended)
bash# 1. Clone the repository
git clone https://github.com/[your-team]/gigshield-devtrails2026.git
cd gigshield-devtrails2026

# 2. Copy environment variables
cp .env.example .env
# Open .env and fill in your API keys (see API Integrations doc)

# 3. Build and start all services
docker-compose up --build

# Services started:
#   React PWA     → http://localhost:3000
#   Express API   → http://localhost:5000
#   FastAPI ML    → http://localhost:8000
#   PostgreSQL    → localhost:5432
#   Redis         → localhost:6379

Manual Setup (Without Docker)
Step 1: Frontend
bashcd frontend
npm install
cp .env.example .env.local
# Set VITE_API_URL=http://localhost:5000
npm run dev
# App runs on http://localhost:3000
Step 2: Backend
bashcd backend
npm install
cp .env.example .env
# Fill in DATABASE_URL, REDIS_URL, JWT_SECRET, and API keys

# Run database migrations
npm run db:migrate

# Seed demo data
npm run db:seed

# Start development server
npm run dev
# API runs on http://localhost:5000
Step 3: ML Service
bashcd ml
python -m venv venv
source venv/bin/activate        # Windows: venv\Scripts\activate
pip install -r requirements.txt

# Train models (uses synthetic data for MVP)
python training/train_models.py

# Start ML API server
uvicorn serve:app --reload --port 8000
# ML API runs on http://localhost:8000

Environment Variables
Create .env file in the project root (or per-service as shown above):
bash# ── Weather & Environment ──────────────────────────────
OWM_API_KEY=your_openweathermap_api_key
OPENAQ_API_KEY=your_openaq_api_key
NEWS_API_KEY=your_newsapi_org_key

# ── Payment (Razorpay Sandbox) ─────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret
RAZORPAY_ACCOUNT_NUMBER=your_account_number

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://gigshield:password@localhost:5432/gigshield_db

# ── Cache & Queue ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=your_secret_key_minimum_32_characters_long
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Notifications ──────────────────────────────────────
FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key
MSG91_API_KEY=your_msg91_api_key
MSG91_TEMPLATE_ID=your_otp_template_id

# ── ML Service ─────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

